{
    "buildCommand": "npm run build",
    "outputDirectory": "dist",
    "framework": "vite",
    "functions": {
        "api/analyze.js": {
            "memory": 256,
            "maxDuration": 30
        }
    },
    "rewrites": [
        {
            "source": "/analyze",
            "destination": "/api/analyze"
        },
        {
            "source": "/((?!api/).*)",
            "destination": "/index.html"
        }
    ]
}